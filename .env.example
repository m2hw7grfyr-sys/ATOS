# Backend
APP_NAME=ATOS API
APP_VERSION=1.0.0-rc.1
APP_ENV=development
DEBUG=false
DATABASE_URL=sqlite:///atos.db
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
COOKIE_SECURE=false
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=storage/logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7
LOG_RETENTION_DAYS=14

# Configurable defaults
DEFAULT_PLATFORM=reddit
DEFAULT_AI_PROVIDER=mock
DEFAULT_AI_MODEL=mock-v0.3

# API / Frontend
API_BASE_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000
PUBLIC_API_BASE_URL=https://atos.example.com

# Remote Worker / Cloudflare Tunnel
WORKER_API_TOKEN=
WORKER_TOKEN_VERSION=v1
WORKER_HEARTBEAT_TIMEOUT_SECONDS=90
MAIN_BIND_HOST=0.0.0.0
MAIN_PORT=8080
GPU_WORKER_API_KEY=
GPU_HEARTBEAT_TIMEOUT_SECONDS=30
GPU_TASK_LEASE_SECONDS=600
ADMIN_DEFAULT_PASSWORD_CHANGED=false
PRODUCTION_GUARD_ENABLED=true
ATOS_SERVER_URL=https://atos.example.com
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_NAME=atos-worker
CLOUDFLARE_WORKER_DOMAIN=worker.example.com

# Data Center
APIFY_TOKEN=
APIFY_API_BASE_URL=https://api.apify.com/v2

# AI Workspace
OPENAI_API_KEY=

# Execution / TGE
TGE_API_BASE_URL=http://127.0.0.1:50326
TGE_API_KEY=
PLAYWRIGHT_MOCK_MODE=true

# Docker
POSTGRES_USER=atos
POSTGRES_PASSWORD=atos
POSTGRES_DB=atos
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
