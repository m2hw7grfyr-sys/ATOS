# API / Frontend
API_BASE_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional integrations (not enabled in v0.1)
APIFY_TOKEN=
APIFY_API_TOKEN=
APIFY_ACTOR_ID=
OPENAI_API_KEY=
TGE_API_BASE_URL=http://127.0.0.1:50326
TGE_API_KEY=
