# ATOS staging environment. Replace every CHANGE_ME value before use.
APP_NAME=ATOS API
APP_VERSION=0.15.0-production-foundation
APP_ENV=staging
DEBUG=false
DATABASE_URL=postgresql+psycopg://atos:CHANGE_ME_STAGING_DB_PASSWORD@postgres:5432/atos
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=https://staging-atos.example.com
COOKIE_SECURE=true
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=/app/storage/logs
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=14
LOG_RETENTION_DAYS=14

API_BASE_URL=https://staging-atos.example.com/api
VITE_API_BASE_URL=https://staging-atos.example.com/api
PUBLIC_API_BASE_URL=https://staging-atos.example.com

DEFAULT_PLATFORM=reddit
DEFAULT_AI_PROVIDER=mock
DEFAULT_AI_MODEL=mock-v0.3

APIFY_TOKEN=
APIFY_API_BASE_URL=https://api.apify.com/v2
OPENAI_API_KEY=
TGE_API_BASE_URL=
TGE_API_KEY=
PLAYWRIGHT_MOCK_MODE=true

WORKER_API_TOKEN=CHANGE_ME_STAGING_WORKER_TOKEN
WORKER_TOKEN_VERSION=v1
WORKER_HEARTBEAT_TIMEOUT_SECONDS=90
ADMIN_DEFAULT_PASSWORD_CHANGED=true
PRODUCTION_GUARD_ENABLED=true

POSTGRES_USER=atos
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
POSTGRES_DB=atos
