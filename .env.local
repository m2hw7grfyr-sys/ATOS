# Local development defaults. Copy to .env for personal overrides.
APP_NAME=ATOS API
APP_VERSION=1.2.0
APP_ENV=development
DATABASE_URL=sqlite:///backend/atos.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
LOG_FORMAT=json

API_BASE_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

DEFAULT_PLATFORM=reddit
DEFAULT_AI_PROVIDER=mock
DEFAULT_AI_MODEL=mock-v0.3

APIFY_TOKEN=
APIFY_API_BASE_URL=https://api.apify.com/v2
OPENAI_API_KEY=
TGE_API_BASE_URL=http://127.0.0.1:50326
TGE_API_KEY=
PLAYWRIGHT_MOCK_MODE=true

POSTGRES_USER=atos
POSTGRES_PASSWORD=atos
POSTGRES_DB=atos
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
